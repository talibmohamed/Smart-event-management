{
  "metadata": {
    "name": "Smart Event Management Backend API",
    "version": "1.0.0",
    "lastUpdated": "2026-04-11",
    "baseUrl": "http://localhost:5000"
  },
  "development": {
    "seedCommand": "npm run db:seed",
    "paymentSchemaCommand": "npm run db:payment-schema",
    "storageSetupCommand": "npm run storage:setup",
    "seedPassword": "Password123!",
    "seedUsers": [
      "admin@smartevent.test",
      "organizer1@smartevent.test",
      "organizer2@smartevent.test",
      "attendee1@smartevent.test",
      "attendee2@smartevent.test",
      "attendee3@smartevent.test"
    ],
    "seedEventCities": [
      "Paris",
      "Issy-les-Moulineaux",
      "Lyon",
      "Marseille",
      "Bordeaux",
      "Lille",
      "Nantes",
      "Toulouse"
    ]
  },
  "environment": {
    "eventImageStorage": {
      "SUPABASE_URL": "Required Supabase project URL",
      "SUPABASE_SERVICE_ROLE_KEY": "Required backend-only service role key",
      "SUPABASE_EVENT_IMAGES_BUCKET": "Public storage bucket name, default event-images"
    },
    "stripeCheckout": {
      "STRIPE_SECRET_KEY": "Required backend-only Stripe secret key",
      "STRIPE_WEBHOOK_SECRET": "Required for webhook signature verification",
      "STRIPE_CURRENCY": "Payment currency, default eur",
      "FRONTEND_URL": "Frontend base URL for Stripe success and cancel redirects"
    }
  },
  "authentication": {
    "type": "bearer-jwt",
    "header": "Authorization",
    "format": "Bearer <token>"
  },
  "roles": ["attendee", "organizer", "admin"],
  "notes": {
    "dateFormat": "ISO-8601 string",
    "uuidFormat": "string",
    "decimalSerialization": "Prisma Decimal values are serialized as strings in JSON",
    "coordinateSerialization": "Event latitude and longitude are generated by backend geocoding and serialized as decimal strings",
    "geocoding": "Event create and update geocode address + city + France through backend-only Nominatim requests. Frontend must not call Nominatim directly.",
    "databaseConnection": "Runtime Prisma connection normalizes Supabase pooler URLs with pgbouncer=true and connection_limit=1.",
    "eventImages": "Event cover images are uploaded by the backend to Supabase Storage. API responses expose image_url only and never expose image_path.",
    "responseException": "GET /api/auth/me returns success and data without message on success"
  },
  "schemas": {
    "authUser": {
      "id": "string(uuid)",
      "first_name": "string",
      "last_name": "string",
      "email": "string",
      "role": "string(attendee|organizer|admin)"
    },
    "userProfile": {
      "id": "string(uuid)",
      "first_name": "string",
      "last_name": "string",
      "email": "string",
      "role": "string(attendee|organizer|admin)",
      "created_at": "string(datetime)"
    },
    "city": {
      "name": "string",
      "postal_code": "string",
      "department": "string"
    },
    "eventPublic": {
      "id": "string(uuid)",
      "title": "string",
      "description": "string|null",
      "category": "string|null",
      "address": "string|null",
      "city": "string|null",
      "latitude": "string(decimal)|null",
      "longitude": "string(decimal)|null",
      "image_url": "string(url)|null",
      "event_date": "string(datetime)",
      "capacity": "number",
      "price": "string(decimal)",
      "organizer_id": "string(uuid)",
      "created_at": "string(datetime)",
      "confirmed_bookings": "number",
      "remaining_seats": "number",
      "is_full": "boolean",
      "first_name": "string",
      "last_name": "string",
      "organizer_email": "string"
    },
    "eventWriteResult": {
      "id": "string(uuid)",
      "title": "string",
      "description": "string|null",
      "category": "string|null",
      "address": "string|null",
      "city": "string|null",
      "latitude": "string(decimal)|null",
      "longitude": "string(decimal)|null",
      "image_url": "string(url)|null",
      "event_date": "string(datetime)",
      "capacity": "number",
      "price": "string(decimal)",
      "organizer_id": "string(uuid)",
      "created_at": "string(datetime)"
    },
    "booking": {
      "id": "string(uuid)",
      "user_id": "string(uuid)",
      "event_id": "string(uuid)",
      "booking_date": "string(datetime)",
      "status": "string(pending_payment|confirmed|cancelled)",
      "payment_status": "string(unpaid|paid|failed|cancelled|expired)|null",
      "amount_paid": "string(decimal)|null",
      "currency": "string"
    },
    "bookingWithEvent": {
      "id": "string(uuid)",
      "user_id": "string(uuid)",
      "event_id": "string(uuid)",
      "booking_date": "string(datetime)",
      "status": "string(pending_payment|confirmed|cancelled)",
      "payment_status": "string(unpaid|paid|failed|cancelled|expired)|null",
      "amount_paid": "string(decimal)|null",
      "currency": "string",
      "title": "string",
      "description": "string|null",
      "category": "string|null",
      "address": "string|null",
      "city": "string|null",
      "latitude": "string(decimal)|null",
      "longitude": "string(decimal)|null",
      "image_url": "string(url)|null",
      "event_date": "string(datetime)",
      "capacity": "number",
      "price": "string(decimal)",
      "organizer_id": "string(uuid)"
    }
    ,
    "bookingCreateFreeResult": {
      "booking": "booking",
      "payment_required": false
    },
    "bookingCreatePaidResult": {
      "booking": "booking",
      "payment_required": true,
      "payment": {
        "provider": "stripe",
        "checkout_url": "string(url)"
      }
    }
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Smart Event Management API is running"
        }
      },
      "commonErrors": []
    },
    {
      "method": "GET",
      "path": "/api/test/db",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Database connection successful",
          "data": {
            "connected": true,
            "user_count": "number"
          }
        }
      },
      "commonErrors": [
        {
          "status": 500,
          "message": "Database connection failed"
        }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/register",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "first_name": { "type": "string", "required": true },
        "last_name": { "type": "string", "required": true },
        "email": { "type": "string", "required": true },
        "password": { "type": "string", "required": true },
        "role": {
          "type": "string",
          "required": false,
          "allowedValues": ["attendee", "organizer"],
          "fallback": "attendee"
        }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "success": true,
          "message": "User registered successfully",
          "data": {
            "token": "string",
            "user": "authUser"
          }
        }
      },
      "commonErrors": [
        { "status": 400, "message": "All fields are required" },
        { "status": 400, "message": "Email already in use" },
        { "status": 500, "message": "Server error during registration" }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/login",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "email": { "type": "string", "required": true },
        "password": { "type": "string", "required": true }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Login successful",
          "data": {
            "token": "string",
            "user": "authUser"
          }
        }
      },
      "commonErrors": [
        { "status": 400, "message": "Invalid credentials" },
        { "status": 500, "message": "Server error during login" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/auth/me",
      "authRequired": true,
      "allowedRoles": ["attendee", "organizer", "admin"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "data": "userProfile"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 401, "message": "Token invalid" },
        { "status": 500, "message": "Server error" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/cities",
      "authRequired": false,
      "allowedRoles": ["public"],
      "queryParams": {
        "search": {
          "type": "string",
          "required": false,
          "description": "Matches approved French city name or postal code"
        }
      },
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Cities retrieved successfully",
          "data": ["city"]
        }
      },
      "commonErrors": [],
      "behaviorNotes": [
        "Public endpoint.",
        "Returns a maximum of 20 results.",
        "The same backend city list is used to validate event create and update payloads."
      ]
    },
    {
      "method": "GET",
      "path": "/api/events",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Events retrieved successfully",
          "data": ["eventPublic"]
        }
      },
      "commonErrors": [
        { "status": 500, "message": "Server error while fetching events" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/events/:id",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event retrieved successfully",
          "data": "eventPublic"
        }
      },
      "commonErrors": [
        { "status": 404, "message": "Event not found" },
        { "status": 500, "message": "Server error while fetching event" }
      ]
    },
    {
      "method": "POST",
      "path": "/api/events",
      "authRequired": true,
      "allowedRoles": ["organizer", "admin"],
      "contentTypes": ["application/json", "multipart/form-data"],
      "requestBody": {
        "title": { "type": "string", "required": true },
        "description": { "type": "string", "required": true },
        "category": { "type": "string", "required": true },
        "address": { "type": "string", "required": true },
        "city": {
          "type": "string",
          "required": true,
          "source": "GET /api/cities",
          "validation": "Must be a backend-approved French city name"
        },
        "event_date": { "type": "string(datetime)", "required": true },
        "capacity": { "type": "number", "required": true, "minimum": 1 },
        "price": { "type": "number", "required": true, "minimum": 0 },
        "cover_image": {
          "type": "file",
          "required": false,
          "contentType": ["image/jpeg", "image/png", "image/webp"],
          "maxSize": "5MB",
          "multipartOnly": true
        }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "success": true,
          "message": "Event created successfully",
          "data": "eventWriteResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 400, "message": "All event fields are required" },
        { "status": 400, "message": "Capacity must be a positive number" },
        { "status": 400, "message": "Price must be a valid number greater than or equal to 0" },
        { "status": 400, "message": "City must be a supported French city" },
        { "status": 400, "message": "Address could not be located" },
        { "status": 400, "message": "Event image must be a JPEG, PNG, or WebP file under 5MB" },
        { "status": 500, "message": "Server error while creating event" }
      ],
      "behaviorNotes": [
        "Frontend must not send latitude or longitude.",
        "Backend geocodes address + city + France using Nominatim and stores latitude and longitude.",
        "When cover_image is present, backend uploads it to Supabase Storage and stores image_url plus internal image_path.",
        "API response includes image_url but never image_path."
      ]
    },
    {
      "method": "PUT",
      "path": "/api/events/:id",
      "authRequired": true,
      "allowedRoles": ["organizer", "admin"],
      "contentTypes": ["application/json", "multipart/form-data"],
      "requestBody": {
        "title": { "type": "string", "required": true },
        "description": { "type": "string", "required": true },
        "category": { "type": "string", "required": true },
        "address": { "type": "string", "required": true },
        "city": {
          "type": "string",
          "required": true,
          "source": "GET /api/cities",
          "validation": "Must be a backend-approved French city name"
        },
        "event_date": { "type": "string(datetime)", "required": true },
        "capacity": { "type": "number", "required": true, "minimum": 1 },
        "price": { "type": "number", "required": true, "minimum": 0 },
        "cover_image": {
          "type": "file",
          "required": false,
          "contentType": ["image/jpeg", "image/png", "image/webp"],
          "maxSize": "5MB",
          "multipartOnly": true
        },
        "remove_image": {
          "type": "boolean|string",
          "required": false,
          "description": "Set to true or 'true' to remove the existing cover image"
        }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event updated successfully",
          "data": "eventWriteResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 404, "message": "Event not found" },
        { "status": 403, "message": "Access denied. You can only update your own events" },
        { "status": 400, "message": "All event fields are required" },
        { "status": 400, "message": "Capacity must be a positive number" },
        { "status": 400, "message": "Price must be a valid number greater than or equal to 0" },
        { "status": 400, "message": "City must be a supported French city" },
        { "status": 400, "message": "Address could not be located" },
        { "status": 400, "message": "Event image must be a JPEG, PNG, or WebP file under 5MB" },
        { "status": 500, "message": "Server error while updating event" }
      ],
      "behaviorNotes": [
        "Frontend must not send latitude or longitude.",
        "Backend geocodes address + city + France using Nominatim when address or city changes.",
        "New cover_image replaces the old image and deletes the old storage object best-effort.",
        "remove_image=true deletes the old storage object best-effort and clears image_url.",
        "API response includes image_url but never image_path."
      ]
    },
    {
      "method": "DELETE",
      "path": "/api/events/:id",
      "authRequired": true,
      "allowedRoles": ["organizer", "admin"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event deleted successfully",
          "data": "eventWriteResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 404, "message": "Event not found" },
        { "status": 403, "message": "Access denied. You can only delete your own events" },
        { "status": 500, "message": "Server error while deleting event" }
      ],
      "behaviorNotes": [
        "Stored event image cleanup is best-effort.",
        "API response includes image_url but never image_path."
      ]
    },
    {
      "method": "GET",
      "path": "/api/bookings/my-bookings",
      "authRequired": true,
      "allowedRoles": ["attendee"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Bookings retrieved successfully",
          "data": ["bookingWithEvent"]
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 401, "message": "Token invalid" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 500, "message": "Server error while fetching bookings" }
      ]
    },
    {
      "method": "POST",
      "path": "/api/bookings",
      "authRequired": true,
      "allowedRoles": ["attendee"],
      "requestBody": {
        "event_id": { "type": "string(uuid)", "required": true }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "success": true,
          "message": "Booking created successfully | Payment required to confirm booking",
          "data": "bookingCreateFreeResult | bookingCreatePaidResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 401, "message": "Token invalid" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 400, "message": "Event ID is required" },
        { "status": 404, "message": "Event not found" },
        { "status": 409, "message": "You have already booked this event" },
        { "status": 409, "message": "You already have a pending payment for this event" },
        { "status": 400, "message": "This event is fully booked" },
        { "status": 500, "message": "Server error while creating booking" }
      ],
      "behaviorNotes": [
        "Free events create confirmed bookings immediately.",
        "Paid events create pending_payment bookings and return a Stripe Checkout URL.",
        "Pending paid bookings do not reserve seats.",
        "Stripe success redirect does not confirm payment; webhook confirmation is required."
      ]
    },
    {
      "method": "GET",
      "path": "/api/bookings/:id",
      "authRequired": true,
      "allowedRoles": ["attendee_owner", "admin"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Booking retrieved successfully",
          "data": "bookingWithEvent"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 401, "message": "Token invalid" },
        { "status": 403, "message": "Access denied. You can only view your own bookings" },
        { "status": 404, "message": "Booking not found" },
        { "status": 500, "message": "Server error while fetching booking" }
      ],
      "behaviorNotes": [
        "Used by frontend to poll booking status after Stripe redirect."
      ]
    },
    {
      "method": "PUT",
      "path": "/api/bookings/:id/cancel",
      "authRequired": true,
      "allowedRoles": ["attendee", "organizer", "admin"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Booking cancelled successfully",
          "data": "booking"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 401, "message": "Token invalid" },
        { "status": 404, "message": "Booking not found" },
        { "status": 403, "message": "Access denied. You can only cancel your own bookings" },
        { "status": 400, "message": "Booking is already cancelled" },
        { "status": 500, "message": "Server error while cancelling booking" }
      ]
    },
    {
      "method": "POST",
      "path": "/api/payments/stripe/webhook",
      "authRequired": false,
      "allowedRoles": ["stripe"],
      "requestBody": "raw Stripe webhook body",
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Stripe webhook processed"
        }
      },
      "commonErrors": [
        { "status": 400, "message": "Invalid Stripe webhook signature" },
        { "status": 500, "message": "Server error while processing Stripe webhook" }
      ],
      "behaviorNotes": [
        "Route must receive raw request body before JSON parsing.",
        "Verifies Stripe-Signature with STRIPE_WEBHOOK_SECRET.",
        "Uses Checkout metadata booking_id, user_id, and event_id.",
        "checkout.session.completed validates metadata, amount, currency, and capacity before confirming.",
        "checkout.session.expired marks pending bookings cancelled with payment_status expired.",
        "Duplicate or already-confirmed webhook events are logged and ignored safely."
      ]
    }
  ],
  "pendingFeatures": [
    "Feedback endpoints",
    "Admin-specific supervision endpoints",
    "Event filtering and pagination",
    "Booking management endpoints beyond my-bookings"
  ]
}
