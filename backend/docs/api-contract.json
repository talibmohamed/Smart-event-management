{
  "metadata": {
    "name": "Smart Event Management Backend API",
    "version": "1.0.0",
    "lastUpdated": "2026-04-13",
    "baseUrl": "http://localhost:5000"
  },
  "development": {
    "seedCommand": "npm run db:seed",
    "paymentSchemaCommand": "npm run db:payment-schema",
    "passwordResetSchemaCommand": "npm run db:password-reset-schema",
    "ticketTierSchemaCommand": "npm run db:ticket-tier-schema",
    "storageSetupCommand": "npm run storage:setup",
    "seedPassword": "Password123!",
    "seedUsers": [
      "admin@smartevent.test",
      "organizer1@smartevent.test",
      "organizer2@smartevent.test",
      "attendee1@smartevent.test",
      "attendee2@smartevent.test",
      "attendee3@smartevent.test"
    ],
    "seedEventCities": [
      "Paris",
      "Issy-les-Moulineaux",
      "Lyon",
      "Marseille",
      "Bordeaux",
      "Lille",
      "Nantes",
      "Toulouse"
    ]
  },
  "environment": {
    "eventImageStorage": {
      "SUPABASE_URL": "Required Supabase project URL",
      "SUPABASE_SERVICE_ROLE_KEY": "Required backend-only service role key",
      "SUPABASE_EVENT_IMAGES_BUCKET": "Public storage bucket name, default event-images"
    },
    "stripeCheckout": {
      "STRIPE_SECRET_KEY": "Required backend-only Stripe secret key",
      "STRIPE_WEBHOOK_SECRET": "Required for webhook signature verification",
      "STRIPE_CURRENCY": "Payment currency, default eur",
      "FRONTEND_URL": "Frontend base URL for Stripe success and cancel redirects"
    },
    "transactionalEmail": {
      "RESEND_API_KEY": "Required Resend API key when EMAIL_ENABLED is not false",
      "EMAIL_FROM": "Required sender address",
      "EMAIL_REPLY_TO": "Optional reply-to address",
      "EMAIL_ENABLED": "Set to false to disable email sending"
    }
  },
  "authentication": {
    "type": "bearer-jwt",
    "header": "Authorization",
    "format": "Bearer <token>"
  },
  "roles": ["attendee", "organizer", "admin"],
  "notes": {
    "dateFormat": "ISO-8601 string",
    "uuidFormat": "string",
    "decimalSerialization": "Prisma Decimal values are serialized as strings in JSON",
    "coordinateSerialization": "Event latitude and longitude are generated by backend geocoding and serialized as decimal strings",
    "geocoding": "Event create and update geocode address + city + France through backend-only Nominatim requests. Frontend must not call Nominatim directly.",
    "databaseConnection": "Runtime Prisma connection normalizes Supabase pooler URLs with pgbouncer=true and connection_limit=1.",
    "eventImages": "Event cover images are uploaded by the backend to Supabase Storage. API responses expose image_url only and never expose image_path.",
    "transactionalEmail": "Resend emails are sent best-effort for booking/payment/event lifecycle actions and never determine API success or failure.",
    "passwordReset": "Forgot password responses do not reveal whether an email exists. Reset tokens are emailed, stored hashed, and expire after 60 minutes.",
    "ticketTiers": "Events use ticket_tiers for pricing and availability. Event.price remains as the minimum active tier price for compatibility.",
    "responseException": "GET /api/auth/me returns success and data without message on success"
  },
  "schemas": {
    "authUser": {
      "id": "string(uuid)",
      "first_name": "string",
      "last_name": "string",
      "email": "string",
      "role": "string(attendee|organizer|admin)"
    },
    "userProfile": {
      "id": "string(uuid)",
      "first_name": "string",
      "last_name": "string",
      "email": "string",
      "role": "string(attendee|organizer|admin)",
      "created_at": "string(datetime)"
    },
    "city": {
      "name": "string",
      "postal_code": "string",
      "department": "string"
    },
    "eventPublic": {
      "id": "string(uuid)",
      "title": "string",
      "description": "string|null",
      "category": "string|null",
      "address": "string|null",
      "city": "string|null",
      "latitude": "string(decimal)|null",
      "longitude": "string(decimal)|null",
      "image_url": "string(url)|null",
      "event_date": "string(datetime)",
      "capacity": "number",
      "price": "string(decimal)",
      "organizer_id": "string(uuid)",
      "created_at": "string(datetime)",
      "confirmed_bookings": "number",
      "remaining_seats": "number",
      "is_full": "boolean",
      "min_price": "string(decimal)",
      "max_price": "string(decimal)",
      "ticket_tiers": ["ticketTier"],
      "first_name": "string",
      "last_name": "string",
      "organizer_email": "string"
    },
    "eventWriteResult": {
      "id": "string(uuid)",
      "title": "string",
      "description": "string|null",
      "category": "string|null",
      "address": "string|null",
      "city": "string|null",
      "latitude": "string(decimal)|null",
      "longitude": "string(decimal)|null",
      "image_url": "string(url)|null",
      "event_date": "string(datetime)",
      "capacity": "number",
      "price": "string(decimal)",
      "organizer_id": "string(uuid)",
      "created_at": "string(datetime)",
      "min_price": "string(decimal)",
      "max_price": "string(decimal)",
      "confirmed_bookings": "number",
      "remaining_seats": "number",
      "is_full": "boolean",
      "ticket_tiers": ["ticketTier"]
    },
    "ticketTier": {
      "id": "string(uuid)",
      "event_id": "string(uuid)",
      "name": "string",
      "description": "string|null",
      "price": "string(decimal)",
      "capacity": "number",
      "sold_quantity": "number",
      "remaining_quantity": "number",
      "is_active": "boolean",
      "sort_order": "number",
      "created_at": "string(datetime)"
    },
    "bookingItem": {
      "id": "string(uuid)",
      "booking_id": "string(uuid)",
      "ticket_tier_id": "string(uuid)",
      "quantity": "number",
      "unit_price": "string(decimal)",
      "total_price": "string(decimal)",
      "ticket_tier": {
        "id": "string(uuid)",
        "name": "string",
        "description": "string|null",
        "price": "string(decimal)"
      }
    },
    "booking": {
      "id": "string(uuid)",
      "user_id": "string(uuid)",
      "event_id": "string(uuid)",
      "booking_date": "string(datetime)",
      "status": "string(pending_payment|confirmed|cancelled)",
      "payment_status": "string(unpaid|paid|failed|cancelled|expired)|null",
      "amount_paid": "string(decimal)|null",
      "currency": "string",
      "items": ["bookingItem"],
      "total_quantity": "number",
      "total_price": "string(decimal)"
    },
    "bookingWithEvent": {
      "id": "string(uuid)",
      "user_id": "string(uuid)",
      "event_id": "string(uuid)",
      "booking_date": "string(datetime)",
      "status": "string(pending_payment|confirmed|cancelled)",
      "payment_status": "string(unpaid|paid|failed|cancelled|expired)|null",
      "amount_paid": "string(decimal)|null",
      "currency": "string",
      "title": "string",
      "description": "string|null",
      "category": "string|null",
      "address": "string|null",
      "city": "string|null",
      "latitude": "string(decimal)|null",
      "longitude": "string(decimal)|null",
      "image_url": "string(url)|null",
      "event_date": "string(datetime)",
      "capacity": "number",
      "price": "string(decimal)",
      "organizer_id": "string(uuid)",
      "items": ["bookingItem"],
      "total_quantity": "number",
      "total_price": "string(decimal)"
    },
    "eventAttendee": {
      "booking_id": "string(uuid)",
      "booking_date": "string(datetime)",
      "status": "string(pending_payment|confirmed|cancelled)",
      "payment_status": "string(unpaid|paid|failed|cancelled|expired)|null",
      "total_quantity": "number",
      "total_price": "string(decimal)",
      "attendee": {
        "id": "string(uuid)",
        "first_name": "string",
        "last_name": "string",
        "email": "string"
      },
      "items": [
        {
          "ticket_tier_id": "string(uuid)",
          "ticket_tier_name": "string",
          "quantity": "number",
          "unit_price": "string(decimal)",
          "total_price": "string(decimal)"
        }
      ]
    },
    "bookingCreateFreeResult": {
      "booking": "booking",
      "payment_required": false
    },
    "bookingCreatePaidResult": {
      "booking": "booking",
      "payment_required": true,
      "payment": {
        "provider": "stripe",
        "checkout_url": "string(url)"
      }
    }
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Smart Event Management API is running"
        }
      },
      "commonErrors": []
    },
    {
      "method": "GET",
      "path": "/api/test/db",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Database connection successful",
          "data": {
            "connected": true,
            "user_count": "number"
          }
        }
      },
      "commonErrors": [
        {
          "status": 500,
          "message": "Database connection failed"
        }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/register",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "first_name": { "type": "string", "required": true },
        "last_name": { "type": "string", "required": true },
        "email": { "type": "string", "required": true },
        "password": { "type": "string", "required": true },
        "role": {
          "type": "string",
          "required": false,
          "allowedValues": ["attendee", "organizer"],
          "fallback": "attendee"
        }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "success": true,
          "message": "User registered successfully",
          "data": {
            "token": "string",
            "user": "authUser"
          }
        }
      },
      "commonErrors": [
        { "status": 400, "message": "All fields are required" },
        { "status": 400, "message": "Email already in use" },
        { "status": 500, "message": "Server error during registration" }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/login",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "email": { "type": "string", "required": true },
        "password": { "type": "string", "required": true }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Login successful",
          "data": {
            "token": "string",
            "user": "authUser"
          }
        }
      },
      "commonErrors": [
        { "status": 400, "message": "Invalid credentials" },
        { "status": 500, "message": "Server error during login" }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/forgot-password",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "email": { "type": "string(email)", "required": true }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "If an account exists for this email, a password reset link has been sent"
        }
      },
      "commonErrors": [
        { "status": 400, "message": "Email is required" },
        { "status": 500, "message": "Server error during password reset request" }
      ],
      "behaviorNotes": [
        "Public endpoint.",
        "Does not reveal whether the account exists.",
        "If account exists, stores a SHA-256 reset token hash and emails FRONTEND_URL/reset-password?token=<token> through Resend.",
        "Reset token expires after 60 minutes.",
        "Email delivery is best-effort and not part of the API success/failure contract."
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/reset-password",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "token": { "type": "string", "required": true },
        "password": { "type": "string", "required": true, "minimumLength": 6 }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Password reset successfully"
        }
      },
      "commonErrors": [
        { "status": 400, "message": "Token and password are required" },
        { "status": 400, "message": "Password must be at least 6 characters" },
        { "status": 400, "message": "Invalid or expired password reset token" },
        { "status": 500, "message": "Server error during password reset" }
      ],
      "behaviorNotes": [
        "Public endpoint.",
        "Uses the raw token from the email URL.",
        "Backend hashes the token and compares it with the stored token hash.",
        "On success, updates password_hash and clears reset token fields."
      ]
    },
    {
      "method": "GET",
      "path": "/api/auth/me",
      "authRequired": true,
      "allowedRoles": ["attendee", "organizer", "admin"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "data": "userProfile"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 401, "message": "Token invalid" },
        { "status": 500, "message": "Server error" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/cities",
      "authRequired": false,
      "allowedRoles": ["public"],
      "queryParams": {
        "search": {
          "type": "string",
          "required": false,
          "description": "Matches approved French city name or postal code"
        }
      },
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Cities retrieved successfully",
          "data": ["city"]
        }
      },
      "commonErrors": [],
      "behaviorNotes": [
        "Public endpoint.",
        "Returns a maximum of 20 results.",
        "The same backend city list is used to validate event create and update payloads."
      ]
    },
    {
      "method": "GET",
      "path": "/api/events",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Events retrieved successfully",
          "data": ["eventPublic"]
        }
      },
      "commonErrors": [
        { "status": 500, "message": "Server error while fetching events" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/events/:id",
      "authRequired": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event retrieved successfully",
          "data": "eventPublic"
        }
      },
      "commonErrors": [
        { "status": 404, "message": "Event not found" },
        { "status": 500, "message": "Server error while fetching event" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/events/:id/attendees",
      "authRequired": true,
      "allowedRoles": ["organizer_owner", "admin"],
      "queryParams": {
        "status": {
          "type": "string",
          "required": false,
          "allowedValues": ["confirmed", "pending_payment", "cancelled", "all"],
          "default": "confirmed"
        }
      },
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event attendees retrieved successfully",
          "data": {
            "event": {
              "id": "string(uuid)",
              "title": "string",
              "status_filter": "string"
            },
            "attendees": ["eventAttendee"]
          }
        }
      },
      "commonErrors": [
        { "status": 400, "message": "Invalid attendee status filter" },
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 403, "message": "Access denied. You can only view attendees for your own events" },
        { "status": 404, "message": "Event not found" },
        { "status": 500, "message": "Server error while fetching event attendees" }
      ],
      "behaviorNotes": [
        "Default status filter is confirmed.",
        "status=all includes confirmed, pending_payment, and cancelled bookings.",
        "Attendees are sorted by booking_date DESC.",
        "total_quantity is the sum of booking item quantities.",
        "total_price is the sum of booking item total prices."
      ]
    },
    {
      "method": "POST",
      "path": "/api/events",
      "authRequired": true,
      "allowedRoles": ["organizer", "admin"],
      "contentTypes": ["application/json", "multipart/form-data"],
      "requestBody": {
        "title": { "type": "string", "required": true },
        "description": { "type": "string", "required": true },
        "category": { "type": "string", "required": true },
        "address": { "type": "string", "required": true },
        "city": {
          "type": "string",
          "required": true,
          "source": "GET /api/cities",
          "validation": "Must be a backend-approved French city name"
        },
        "event_date": { "type": "string(datetime)", "required": true },
        "capacity": { "type": "number", "required": true, "minimum": 1 },
        "price": { "type": "number", "required": true, "minimum": 0 },
        "ticket_tiers": {
          "type": "array|json-string",
          "required": false,
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "name": "string required",
            "description": "string optional",
            "price": "number >= 0 required",
            "capacity": "number > 0 required",
            "is_active": "boolean optional",
            "sort_order": "number optional"
          },
          "fallback": "When omitted, backend creates one active Standard tier from Event.price and Event.capacity"
        },
        "cover_image": {
          "type": "file",
          "required": false,
          "contentType": ["image/jpeg", "image/png", "image/webp"],
          "maxSize": "5MB",
          "multipartOnly": true
        }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "success": true,
          "message": "Event created successfully",
          "data": "eventWriteResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 400, "message": "All event fields are required" },
        { "status": 400, "message": "Capacity must be a positive number" },
        { "status": 400, "message": "Price must be a valid number greater than or equal to 0" },
        { "status": 400, "message": "City must be a supported French city" },
        { "status": 400, "message": "Address could not be located" },
        { "status": 400, "message": "Event must have between 1 and 10 ticket tiers" },
        { "status": 400, "message": "Each ticket tier requires name, price >= 0, and capacity > 0" },
        { "status": 400, "message": "Ticket tier capacities cannot exceed event capacity" },
        { "status": 400, "message": "Event image must be a JPEG, PNG, or WebP file under 5MB" },
        { "status": 500, "message": "Server error while creating event" }
      ],
      "behaviorNotes": [
        "Frontend must not send latitude or longitude.",
        "Backend geocodes address + city + France using Nominatim and stores latitude and longitude.",
        "When cover_image is present, backend uploads it to Supabase Storage and stores image_url plus internal image_path.",
        "API response includes image_url but never image_path.",
        "Event.price is stored/returned as the minimum active ticket tier price."
      ]
    },
    {
      "method": "PUT",
      "path": "/api/events/:id",
      "authRequired": true,
      "allowedRoles": ["organizer", "admin"],
      "contentTypes": ["application/json", "multipart/form-data"],
      "requestBody": {
        "title": { "type": "string", "required": true },
        "description": { "type": "string", "required": true },
        "category": { "type": "string", "required": true },
        "address": { "type": "string", "required": true },
        "city": {
          "type": "string",
          "required": true,
          "source": "GET /api/cities",
          "validation": "Must be a backend-approved French city name"
        },
        "event_date": { "type": "string(datetime)", "required": true },
        "capacity": { "type": "number", "required": true, "minimum": 1 },
        "price": { "type": "number", "required": true, "minimum": 0 },
        "ticket_tiers": {
          "type": "array|json-string",
          "required": false,
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "id": "string(uuid) optional existing tier id",
            "name": "string required",
            "description": "string optional",
            "price": "number >= 0 required",
            "capacity": "number > 0 required",
            "is_active": "boolean optional",
            "sort_order": "number optional"
          },
          "fallback": "When omitted, backend preserves existing tiers"
        },
        "cover_image": {
          "type": "file",
          "required": false,
          "contentType": ["image/jpeg", "image/png", "image/webp"],
          "maxSize": "5MB",
          "multipartOnly": true
        },
        "remove_image": {
          "type": "boolean|string",
          "required": false,
          "description": "Set to true or 'true' to remove the existing cover image"
        }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event updated successfully",
          "data": "eventWriteResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 404, "message": "Event not found" },
        { "status": 403, "message": "Access denied. You can only update your own events" },
        { "status": 400, "message": "All event fields are required" },
        { "status": 400, "message": "Capacity must be a positive number" },
        { "status": 400, "message": "Price must be a valid number greater than or equal to 0" },
        { "status": 400, "message": "City must be a supported French city" },
        { "status": 400, "message": "Address could not be located" },
        { "status": 400, "message": "Event must have between 1 and 10 ticket tiers" },
        { "status": 400, "message": "Each ticket tier requires name, price >= 0, and capacity > 0" },
        { "status": 400, "message": "Ticket tier capacities cannot exceed event capacity" },
        { "status": 400, "message": "Ticket tier capacity cannot be lower than sold quantity" },
        { "status": 400, "message": "Sold ticket tiers cannot be deleted" },
        { "status": 400, "message": "Event image must be a JPEG, PNG, or WebP file under 5MB" },
        { "status": 500, "message": "Server error while updating event" }
      ],
      "behaviorNotes": [
        "Frontend must not send latitude or longitude.",
        "Backend geocodes address + city + France using Nominatim when address or city changes.",
        "New cover_image replaces the old image and deletes the old storage object best-effort.",
        "remove_image=true deletes the old storage object best-effort and clears image_url.",
        "API response includes image_url but never image_path.",
        "Sold tiers cannot be deleted and tier capacity cannot be reduced below confirmed sold quantity.",
        "Unsold tiers omitted from an update payload are disabled instead of hard-deleted."
      ]
    },
    {
      "method": "DELETE",
      "path": "/api/events/:id",
      "authRequired": true,
      "allowedRoles": ["organizer", "admin"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Event deleted successfully",
          "data": "eventWriteResult"
        }
      },
      "commonErrors": [
        { "status": 401, "message": "Not authorized" },
        { "status": 403, "message": "Access denied. Insufficient permissions" },
        { "status": 404, "message": "Event not found" },
        { "status": 403, "message": "Access denied. You can only delete your own events" },
        { "status": 500, "message": "Server error while deleting event" }
      ],
      "behaviorNotes": [
        "Stored event image cleanup is best-effort.",
        "API response includes image_url but never image_path."
      ]
    },
    {
      "method": "GET",
      "path": "/api/bookings/my-bookings",
      "authRequired": true,
      "allowedRoles": ["attendee"],
      "requestBody": null,
      "successResponse": {
        "status": 200,
        "body": {
          "success": true,
          "message": "Bookings retrieved successfully",
