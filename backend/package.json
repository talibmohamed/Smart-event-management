{
  "name": "backend",
  "version": "1.0.0",
  "description": "Smart Event Management Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "storage:setup": "node scripts/setupEventImagesBucket.js",
    "db:payment-schema": "node scripts/applyBookingPaymentSchema.js",
    "db:password-reset-schema": "node scripts/applyPasswordResetSchema.js",
    "db:ticket-tier-schema": "node scripts/applyTicketTierSchema.js",
    "db:notification-schema": "node scripts/applyNotificationSchema.js",
    "db:ticket-schema": "node scripts/applyTicketSchema.js",
    "email:preview": "node scripts/sendEmailPreviews.js",
    "postinstall": "npm run prisma:generate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "prisma": "6.19.2",
    "qrcode": "^1.5.4",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.1",
    "svg-to-pdfkit": "^0.1.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.10",
    "vitest": "^4.1.4"
  }
}
