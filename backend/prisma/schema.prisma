generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(uuid()) @db.Uuid
  first_name                String    @db.VarChar(100)
  last_name                 String    @db.VarChar(100)
  email                     String    @unique @db.VarChar(150)
  password_hash             String
  role                      String    @default("attendee") @db.VarChar(20)
  password_reset_token_hash String?   @db.VarChar(64)
  password_reset_expires_at DateTime?
  created_at                DateTime  @default(now())

  events       Event[]
  bookings     Booking[]
  feedbacks    Feedback[]
  tickets      Ticket[]
  notifications Notification[]
  reminder_deliveries EventReminderDelivery[]

  @@index([password_reset_token_hash])
  @@map("users")
}

model Notification {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  type       String    @db.VarChar(50)
  title      String    @db.VarChar(200)
  message    String
  data       Json?
  dedupe_key String?   @db.VarChar(255)
  read_at    DateTime?
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reminder_deliveries EventReminderDelivery[]

  @@unique([user_id, dedupe_key])
  @@index([user_id, created_at])
  @@index([user_id, read_at])
  @@map("notifications")
}

model Event {
  id           String    @id @default(uuid()) @db.Uuid
  title        String    @db.VarChar(200)
  description  String?
  category     String?   @db.VarChar(100)
  address      String?   @db.VarChar(200)
  city         String?   @db.VarChar(100)
  latitude     Decimal?  @db.Decimal(10, 7)
  longitude    Decimal?  @db.Decimal(10, 7)
  image_url    String?   @db.Text
  image_path   String?   @db.VarChar(500)
  event_date   DateTime
  event_end_date DateTime?
  timezone     String    @default("Europe/Paris") @db.VarChar(100)
  capacity     Int
  price        Decimal   @default(0.00) @db.Decimal(10, 2)
  organizer_id String    @db.Uuid
  created_at   DateTime  @default(now())

  organizer    User     @relation(fields: [organizer_id], references: [id])
  bookings     Booking[]
  feedbacks    Feedback[]
  ticket_tiers TicketTier[]
  tickets      Ticket[]
  agenda_tracks EventTrack[]
  agenda_sessions EventSession[]
  reminder_deliveries EventReminderDelivery[]

  @@index([event_date])
  @@map("events")
}

model Booking {
  id                         String   @id @default(uuid()) @db.Uuid
  user_id                    String   @db.Uuid
  event_id                   String   @db.Uuid
  booking_date               DateTime @default(now())
  status                     String   @default("confirmed") @db.VarChar(20)
  payment_status             String?  @db.VarChar(20)
  stripe_checkout_session_id String?  @db.VarChar(255)
  stripe_payment_intent_id   String?  @db.VarChar(255)
  stripe_event_id            String?  @db.VarChar(255)
  amount_paid                Decimal? @db.Decimal(10, 2)
  currency                   String   @default("eur") @db.VarChar(3)

  user         User @relation(fields: [user_id], references: [id])
  event        Event @relation(fields: [event_id], references: [id])
  items        BookingItem[]
  tickets      Ticket[]
  reminder_deliveries EventReminderDelivery[]

  @@unique([user_id, event_id])
  @@map("bookings")
}

model EventTrack {
  id          String   @id @default(uuid()) @db.Uuid
  event_id    String   @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  event    Event          @relation(fields: [event_id], references: [id], onDelete: Cascade)
  sessions EventSession[]

  @@index([event_id])
  @@map("event_tracks")
}

model EventSession {
  id           String   @id @default(uuid()) @db.Uuid
  event_id     String   @db.Uuid
  track_id     String   @db.Uuid
  title        String   @db.VarChar(200)
  description  String?
  speaker_name String?  @db.VarChar(150)
  location     String?  @db.VarChar(150)
  starts_at    DateTime
  ends_at      DateTime
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())

  event Event      @relation(fields: [event_id], references: [id], onDelete: Cascade)
  track EventTrack @relation(fields: [track_id], references: [id], onDelete: Cascade)

  @@index([event_id, starts_at])
  @@index([track_id, starts_at])
  @@map("event_sessions")
}

model EventReminderDelivery {
  id              String    @id @default(uuid()) @db.Uuid
  event_id        String    @db.Uuid
  booking_id      String    @db.Uuid
  user_id         String    @db.Uuid
  reminder_key    String    @db.VarChar(20)
  scheduled_for   DateTime
  sent_at         DateTime?
  notification_id String?   @db.Uuid
  email_sent      Boolean   @default(false)
  retry_count     Int       @default(0)
  last_attempt_at DateTime?
  last_error      String?
  created_at      DateTime  @default(now())

  event        Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  booking      Booking       @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notification Notification? @relation(fields: [notification_id], references: [id], onDelete: SetNull)

  @@unique([event_id, user_id, reminder_key])
  @@index([scheduled_for, sent_at])
  @@index([user_id])
  @@map("event_reminder_deliveries")
}

model TicketTier {
  id          String   @id @default(uuid()) @db.Uuid
  event_id    String   @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  price       Decimal  @default(0.00) @db.Decimal(10, 2)
  capacity    Int
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  event        Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  bookingItems BookingItem[]
  tickets      Ticket[]

  @@index([event_id])
  @@map("ticket_tiers")
}

model BookingItem {
  id             String  @id @default(uuid()) @db.Uuid
  booking_id     String  @db.Uuid
  ticket_tier_id String  @db.Uuid
  quantity       Int
  unit_price     Decimal @db.Decimal(10, 2)
  total_price    Decimal @db.Decimal(10, 2)

  booking    Booking    @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  ticketTier TicketTier @relation(fields: [ticket_tier_id], references: [id])
  tickets    Ticket[]

  @@index([booking_id])
  @@index([ticket_tier_id])
  @@map("booking_items")
}

model Ticket {
  id             String    @id @default(uuid()) @db.Uuid
  booking_id     String    @db.Uuid
  booking_item_id String    @db.Uuid
  event_id       String    @db.Uuid
  user_id        String    @db.Uuid
  ticket_tier_id String    @db.Uuid
  ticket_code    String    @unique @db.VarChar(80)
  status         String    @default("valid") @db.VarChar(20)
  issued_at      DateTime  @default(now())
  checked_in_at  DateTime?

  booking     Booking     @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  bookingItem BookingItem @relation(fields: [booking_item_id], references: [id], onDelete: Cascade)
  event       Event       @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [user_id], references: [id])
  ticketTier  TicketTier  @relation(fields: [ticket_tier_id], references: [id])

  @@index([booking_id])
  @@index([event_id])
  @@index([user_id])
  @@index([ticket_tier_id])
  @@map("tickets")
}

model Feedback {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  event_id   String   @db.Uuid
  rating     Int
  comment    String?
  created_at DateTime @default(now())

  user       User @relation(fields: [user_id], references: [id])
  event      Event @relation(fields: [event_id], references: [id])

  @@unique([user_id, event_id])
  @@map("feedback")
}
